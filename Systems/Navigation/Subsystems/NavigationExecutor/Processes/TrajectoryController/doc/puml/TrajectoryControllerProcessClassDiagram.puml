@startuml
title TrajectoryController Process Class Diagram

namespace fast::fr {
  namespace messages {
  }
  namespace NavigationSystem {
    namespace NavigationExecutorSubsystem {
        interface ITrajectoryControllerProcess  {
          +{abstract} bool update(double current_time_sec, double delta_time_sec)
        }
        abstract BaseTrajectoryControllerProcess {
          +bool base_update(double current_time_sec, double delta_time_sec)

        }
        BaseTrajectoryControllerProcess -up-|> ITrajectoryControllerProcess
        class BasicTrajectoryControllerProcess {
          +bool update(double current_time_sec, double delta_time_sec)
        }
        BasicTrajectoryControllerProcess -up-|> BaseTrajectoryControllerProcess
        class DummyTrajectoryControllerProcess {
          +bool update(double current_time_sec, double delta_time_sec)
        }
        DummyTrajectoryControllerProcess -up-|> BaseTrajectoryControllerProcess
    }
  }
}
@enduml